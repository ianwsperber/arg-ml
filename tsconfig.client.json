{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": [],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/render/assets/arg-render.ts",
    "src/render/assets/arg-render.bootstrap.ts",
    "src/ast/**/*.ts",
    "src/parser/**/*.ts",
    "src/propagation/**/*.ts"
  ],
  "exclude": ["**/*.test.ts"]
}
